# Copy to .env.local for local dev, or set as GitHub Secrets in CI.

# Empty for a custom apex domain (seniorsaferhome.com).
# Set to "/RepoName" when deploying to a GitHub Pages repo subpath.
NEXT_PUBLIC_BASE_PATH=

# Public site URL used for canonicals, sitemap, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://seniorsaferhome.com

# Amazon Associates tag appended to affiliate links if a product omits one.
NEXT_PUBLIC_AMAZON_TAG=seniorsaferhome-20

# Optional analytics (nothing loads unless set). Affiliate clicks are tracked
# automatically in whichever provider is configured.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Newsletter: set to your provider's form POST URL (ConvertKit/Beehiiv/Mailchimp)
# to make the email sign-up live. Leave blank for a disabled "coming soon" form.
NEXT_PUBLIC_NEWSLETTER_ACTION=
NEXT_PUBLIC_NEWSLETTER_FIELD=email_address

# --- Build-time enrichment ONLY (never exposed to the client) ---
# Amazon CREATORS API credentials (OAuth 2.0 / Login with Amazon).
# This replaced the retired Product Advertising API (PA-API) in May 2026.
# Get them from the Amazon Developer console → Creators API → your app →
# "Add new credential". If absent, enrichment falls back to editorial images
# and the build still succeeds.
AMAZON_CREATORS_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxx
AMAZON_CREATORS_CLIENT_SECRET=amzn1.oa2-cs.v1.xxxxxxxx
AMAZON_PARTNER_TAG=seniorsaferhome-20
# Optional overrides (defaults shown):
# AMAZON_CREATORS_SCOPE=creatorsapi::default
# AMAZON_CREATORS_TOKEN_URL=https://api.amazon.com/auth/o2/token
# AMAZON_CREATORS_HOST=creatorsapi.amazon
# AMAZON_MARKETPLACE=www.amazon.com

# Google AdSense publisher client (enables ads + ads.txt + verification snippet)
# Example: ca-pub-1234567890123456
NEXT_PUBLIC_ADSENSE_CLIENT=
