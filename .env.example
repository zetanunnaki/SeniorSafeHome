# Copy to .env.local for local dev, or set as GitHub Secrets in CI.

# Empty for a custom apex domain (seniorsafehome.com).
# Set to "/RepoName" when deploying to a GitHub Pages repo subpath.
NEXT_PUBLIC_BASE_PATH=

# Public site URL used for canonicals, sitemap, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://seniorsafehome.com

# Amazon Associates tag appended to affiliate links if a product omits one.
NEXT_PUBLIC_AMAZON_TAG=seniorsafehome-20

# --- Build-time enrichment ONLY (never exposed to the client) ---
# Amazon Product Advertising API v5 credentials. If absent, enrichment falls
# back to editorial images and the build still succeeds.
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=seniorsafehome-20
AMAZON_HOST=webservices.amazon.com
AMAZON_REGION=us-east-1
